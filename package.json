{
  "name": "classup",
  "version": "0.1.0",
  "private": true,
  "homepage": "https://chenpeleg.github.io/Classup/",
  "dependencies": {
    "axios": "^1",
    "react": "^19",
    "react-dom": "^19"
  },
  "scripts": {
    "start": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write src/",
    "type-check": "tsc --noEmit"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6",
    "@testing-library/react": "^16",
    "@testing-library/user-event": "^14",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "gh-pages": "^6",
    "jsdom": "^25",
    "prettier": "^3.8.1",
    "sass": "^1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "vite": "^7",
    "vitest": "^4"
  }
}
